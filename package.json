{
  "name": "elbe-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "generate:sitemap": "tsx sitemap.ts",
    "build": "pnpm generate:sitemap && ng build",
    "build:pages": "pnpm generate:sitemap && ng build && cp dist/elbeui/browser/index.html dist/elbeui/browser/404.html",
    "watch": "ng build --watch --configuration development",
    "serve:ssr:elbeui": "node dist/elbeui/server/server.mjs",
    "fmt": "prettier --write ."
  },
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@angular/cdk": "22.0.4",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/platform-server": "22.0.6",
    "@angular/router": "22.0.6",
    "@angular/ssr": "22.0.6",
    "@fontsource/noto-mono": "5.2.5",
    "@maplibre/ngx-maplibre-gl": "21.0.2",
    "@ng-icons/core": "34.0.0",
    "@ng-icons/lucide": "34.0.0",
    "@ng-icons/simple-icons": "34.0.0",
    "@spartan-ng/brain": "1.1.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cupertino-pane": "1.5.4",
    "embla-carousel": "8.6.0",
