    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.6",
    "@angular/cli": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@spartan-ng/cli": "1.1.0",
    "@tailwindcss/postcss": "4.3.2",
    "@types/express": "5.0.6",
    "@types/node": "22.19.2",
    "jsdom": "27.4.0",
    "postcss": "8.5.16",
    "prettier": "3.9.5",
    "prettier-plugin-organize-imports": "4.3.0",
